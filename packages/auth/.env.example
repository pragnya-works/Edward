# Used by @edward/auth and Drizzle migrations.
# Note: drizzle-kit reads DATABASE_URL from the current shell environment when you
# run `pnpm --filter @edward/auth db:migrate`, so export it before running that command.
DATABASE_URL="postgresql://postgres:password@localhost:5432/edward"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
# Optional. Set this in split-subdomain production deploys, for example:
# BETTER_AUTH_COOKIE_DOMAIN="edwardd.app"
BETTER_AUTH_COOKIE_DOMAIN=""
# Optional comma-separated extra origins, for example:
# BETTER_AUTH_TRUSTED_ORIGINS="https://www.edwardd.app,https://api.edwardd.app"
BETTER_AUTH_TRUSTED_ORIGINS=""
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
