# Core app URLs
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Auth route handlers in apps/web import @edward/auth, so these server-side values
# are still required in the Next.js app environment.
DATABASE_URL="postgresql://postgres:password@localhost:5432/edward"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Required for provider/model icons rendered by @edward/ui.
NEXT_PUBLIC_ASSETS_URL="https://assets.yourdomain.com"
# Optional extra hostname allow-list for next/image remote patterns.
NEXT_PUBLIC_CDN_URL=""

# Optional changelog integration.
LINEAR_API_KEY=""

# Optional runtime Sentry DSN for client/server instrumentation.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional build-time token for uploading production source maps.
SENTRY_AUTH_TOKEN=""
