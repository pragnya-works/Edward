NEXT_PUBLIC_BETTER_AUTH_URL="https://edwardd.app"
NEXT_PUBLIC_SITE_URL="https://edwardd.app"
# Required in production.
NEXT_PUBLIC_API_URL="https://api.edwardd.app"
# Optional server-only override used by /api/ready to probe API health from inside the web runtime.
# For API subdomain deploys keep this as https://api.edwardd.app unless you have a private internal endpoint.
INTERNAL_API_URL="https://api.edwardd.app"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
BETTER_AUTH_SECRET="your-better-auth-secret"
BETTER_AUTH_URL="https://edwardd.app"
LINEAR_API_KEY="your-linear-api-key"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
NEXT_PUBLIC_ASSETS_URL="https://assets.yourdomain.com"

NEXT_PUBLIC_SENTRY_DSN="https://<public-key>@o<org-id>.ingest.us.sentry.io/<project-id>"
# Optional server-side override. If omitted, NEXT_PUBLIC_SENTRY_DSN is used.
SENTRY_DSN="https://<public-key>@o<org-id>.ingest.us.sentry.io/<project-id>"
SENTRY_ORG="your-sentry-org"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Optional CDN fallback when NEXT_PUBLIC_ASSETS_URL is not set.
NEXT_PUBLIC_CDN_URL=""
