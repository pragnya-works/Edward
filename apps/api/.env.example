API_URL="http://localhost:8000"
EDWARD_API_PORT=8000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
BETTER_AUTH_SECRET="your-better-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here-0123456789abcdef"
OPENAI_MODEL="gpt-5-nano-2025-08-07"
GEMINI_MODEL="gemini-2.5-flash"
REDIS_HOST="localhost"
REDIS_PORT=6379
MAX_ACTIVE_RUNS_PER_USER=2
MAX_ACTIVE_RUNS_PER_CHAT=1
AGENT_RUN_WORKER_CONCURRENCY=2
BUILD_WORKER_CONCURRENCY=3
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
# Max raw tool stdout/stderr payload captured before truncation/compaction.
MAX_RAW_TOOL_STDIO_CHARS=64000
# Max bytes captured from sandbox exec stdout/stderr before truncation (default: 64 MB).
SANDBOX_EXEC_MAX_CAPTURE_BYTES=67108864
PREWARM_SANDBOX_IMAGE="node:20-slim"
EDWARD_DEPLOYMENT_TYPE="subdomain"
TRUST_PROXY="false" #(keep it true if behind a proxy like Nginx or Cloudflare)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_BUCKET_NAME="your-bucket-name"
AWS_CDN_BUCKET_NAME="your-cdn"
ASSETS_URL="https://assets.yourdomain.com"
CLOUDFRONT_DISTRIBUTION_URL="your-cloudfront-url"
CLOUDFRONT_DISTRIBUTION_ID="your-cloudfront-distribution-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_KV_NAMESPACE_ID="your-cloudflare-kv-namespace-id"
PREVIEW_ROOT_DOMAIN="edwardd.app"
TAVILY_API_KEY="tvly-your-tavily-api-key"
