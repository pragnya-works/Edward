API_URL="http://localhost:8000"
API_BASE_PATH=""
EDWARD_API_PORT=8000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
BETTER_AUTH_SECRET="your-better-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Optional compatibility alias used by some auth/test paths.
BETTER_AUTH_BASE_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here-0123456789abcdef"
# Optional Sentry DSN for error reporting.
SENTRY_DSN=""
OPENAI_MODEL="gpt-5-nano-2025-08-07"
GEMINI_MODEL="gemini-2.5-flash"
# Optional single Redis URL alternative to REDIS_HOST/REDIS_PORT.
REDIS_URL=""
REDIS_HOST="localhost"
REDIS_PORT=6379
# Optional Redis ACL credentials when not using REDIS_URL.
REDIS_USERNAME=""
REDIS_PASSWORD=""
# Optional Redis logical DB index.
REDIS_DB=0
# Set true when Redis requires TLS and REDIS_URL is not used.
REDIS_TLS="false"
MAX_ACTIVE_RUNS_PER_USER=2
MAX_ACTIVE_RUNS_PER_CHAT=1
AGENT_RUN_WORKER_CONCURRENCY=2
BUILD_WORKER_CONCURRENCY=3
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
# Max raw tool stdout/stderr payload captured before truncation/compaction.
MAX_RAW_TOOL_STDIO_CHARS=64000
# Max bytes captured from sandbox exec stdout/stderr before truncation (default: 64 MB).
SANDBOX_EXEC_MAX_CAPTURE_BYTES=67108864
# Optional override for reserved output tokens (default 4096).
LLM_RESERVED_OUTPUT_TOKENS=4096
PREWARM_SANDBOX_IMAGE="node:20-slim"
DOCKER_REGISTRY_BASE="ghcr.io/your-org"
# Disable to run API without Docker sandbox runtime.
SANDBOX_ENABLED="true"
EDWARD_DEPLOYMENT_TYPE="subdomain"
TRUST_PROXY="false" #(keep it true if behind a proxy like Nginx or Cloudflare)
AWS_REGION="ap-south-1"
# Optional for local/dev; prefer IAM role credentials on AWS.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_BUCKET_NAME="your-bucket-name"
AWS_CDN_BUCKET_NAME="your-cdn"
ASSETS_URL="https://assets.yourdomain.com"
CLOUDFRONT_DISTRIBUTION_URL="your-cloudfront-url"
CLOUDFRONT_DISTRIBUTION_ID="your-cloudfront-distribution-id"
AWS_CLOUDFRONT_ROLE_ARN=""
AWS_CLOUDFRONT_ROLE_SESSION_NAME="edward-cloudfront-dev"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_KV_NAMESPACE_ID="your-cloudflare-kv-namespace-id"
PREVIEW_ROOT_DOMAIN="edwardd.app"
TAVILY_API_KEY="tvly-your-tavily-api-key"

# Optional runtime tuning and safety limits.
MAX_STREAM_DURATION_MS=1200000
MAX_AGENT_TURNS=12
MAX_AGENT_TOOL_CALLS_PER_TURN=12
MAX_AGENT_TOOL_CALLS_PER_RUN=24
MAX_AGENT_CONTINUATION_PROMPT_CHARS=14000
MAX_AGENT_TOOL_RESULT_PAYLOAD_CHARS=180000
MAX_TOOL_STDIO_CHARS=6000
TOOL_GATEWAY_TIMEOUT_MS=45000
SANDBOX_COMMAND_TIMEOUT_MS=45000
TOOL_GATEWAY_RETRY_ATTEMPTS=2
WORKER_CONCURRENCY=3
MAX_AGENT_QUEUE_DEPTH=200
RUN_MAX_QUEUED_AGE_MS=600000
RUN_MAX_RUNNING_AGE_MS=2700000
RUN_TERMINAL_STATUS_POLL_INTERVAL_MS=2000
WORKER_BUILD_JOB_TIMEOUT_MS=900000
WORKER_BACKUP_JOB_TIMEOUT_MS=300000
WORKER_REDIS_PUBLISH_RETRY_ATTEMPTS=3
WORKER_REDIS_PUBLISH_TIMEOUT_MS=2000
