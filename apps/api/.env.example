# Core server
EDWARD_API_PORT=8000
# Optional platform fallback if EDWARD_API_PORT is not provided:
# PORT=8000
NODE_ENV="development"
# For split frontend/backend deploys, set this to your web app origin (for example Vercel).
CORS_ORIGIN="http://localhost:3000"
TRUST_PROXY="false"

# Auth + persistence
DATABASE_URL="postgresql://postgres:password@localhost:5432/edward"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
ENCRYPTION_KEY="replace-with-openssl-rand-hex-64"
OPENAI_MODEL="gpt-5-nano-2025-08-07"
GEMINI_MODEL="gemini-2.5-flash"

# Redis state / queues
# Set REDIS_URL or REDIS_HOST + REDIS_PORT.
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# Sandbox runtime
# Used by the worker/build pipeline for template resolution and container execution.
DOCKER_REGISTRY_BASE="ghcr.io/your-org/edward"
PREWARM_SANDBOX_IMAGE="node:20-slim"
# Local development is usually easiest in path mode. Use "subdomain" only when
# Cloudflare preview routing is configured.
EDWARD_DEPLOYMENT_TYPE="path"

# Storage / preview placeholders
# AWS_BUCKET_NAME and AWS_CDN_BUCKET_NAME are read during API module loading, so
# keep them populated even if you are stubbing these integrations locally.
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="edward-sandbox"
AWS_CDN_BUCKET_NAME="edward-cdn"
# Optional if your local AWS credential chain already resolves credentials.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Required only for public asset URL generation such as chat image uploads.
ASSETS_URL=""
# Optional preview URL + cache invalidation settings.
CLOUDFRONT_DISTRIBUTION_URL=""
CLOUDFRONT_DISTRIBUTION_ID=""

# Optional subdomain preview routing
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_KV_NAMESPACE_ID=""
PREVIEW_ROOT_DOMAIN=""

# Optional observability / search
SENTRY_DSN=""
TAVILY_API_KEY=""

# Optional tuning
MAX_ACTIVE_RUNS_PER_USER=2
MAX_ACTIVE_RUNS_PER_CHAT=1
AGENT_RUN_WORKER_CONCURRENCY=2
BUILD_WORKER_CONCURRENCY=3
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
MAX_RAW_TOOL_STDIO_CHARS=64000
SANDBOX_EXEC_MAX_CAPTURE_BYTES=67108864
LLM_RESERVED_OUTPUT_TOKENS=4096
# vercel | disabled
SANDBOX_RUNTIME="vercel"
# Set false where sandbox execution is unavailable but the API should still boot.
SANDBOX_RUNTIME_REQUIRED="true"
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""
VERCEL_PROJECT_ID=""
# Optional. Defaults to node22.
VERCEL_SANDBOX_RUNTIME="node22"
# Optional. Defaults to 15 minutes.
VERCEL_SANDBOX_TIMEOUT_MS=900000
# Optional. Defaults to 1 vCPU.
VERCEL_SANDBOX_VCPUS=1
# Optional snapshot IDs for faster framework startup.
VERCEL_SANDBOX_SNAPSHOT_NEXTJS=""
VERCEL_SANDBOX_SNAPSHOT_VITE_REACT=""
VERCEL_SANDBOX_SNAPSHOT_VANILLA=""
