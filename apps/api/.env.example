API_URL="http://localhost:8000"
EDWARD_API_PORT=8000
# Optional platform fallback if EDWARD_API_PORT is not provided:
# PORT=8000
NODE_ENV="development"
# For split frontend/backend deploys, set this to your web app origin (for example Vercel).
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
BETTER_AUTH_SECRET="your-better-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Optional compatibility alias used by some auth/test paths.
BETTER_AUTH_BASE_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here-0123456789abcdef"
# Optional Sentry DSN for error reporting.
SENTRY_DSN=""
OPENAI_MODEL="gpt-5-nano-2025-08-07"
GEMINI_MODEL="gemini-2.5-flash"
# Optional single Redis URL alternative to REDIS_HOST/REDIS_PORT.
# Upstash/Railway commonly use a full rediss:// URL here.
REDIS_URL=""
REDIS_HOST="localhost"
REDIS_PORT=6379
MAX_ACTIVE_RUNS_PER_USER=2
MAX_ACTIVE_RUNS_PER_CHAT=1
AGENT_RUN_WORKER_CONCURRENCY=2
BUILD_WORKER_CONCURRENCY=3
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
# Max raw tool stdout/stderr payload captured before truncation/compaction.
MAX_RAW_TOOL_STDIO_CHARS=64000
# Max bytes captured from sandbox exec stdout/stderr before truncation (default: 64 MB).
SANDBOX_EXEC_MAX_CAPTURE_BYTES=67108864
# Optional override for reserved output tokens (default 4096).
LLM_RESERVED_OUTPUT_TOKENS=4096
# vercel | disabled
SANDBOX_RUNTIME="vercel"
# Set false where sandbox execution is unavailable but the API should still boot.
SANDBOX_RUNTIME_REQUIRED="true"
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""
VERCEL_PROJECT_ID=""
# Optional. Defaults to node22.
VERCEL_SANDBOX_RUNTIME="node22"
# Optional. Defaults to 15 minutes.
VERCEL_SANDBOX_TIMEOUT_MS=900000
# Optional. Defaults to 1 vCPU.
VERCEL_SANDBOX_VCPUS=1
# Optional snapshot IDs for faster framework startup.
VERCEL_SANDBOX_SNAPSHOT_NEXTJS=""
VERCEL_SANDBOX_SNAPSHOT_VITE_REACT=""
VERCEL_SANDBOX_SNAPSHOT_VANILLA=""
EDWARD_DEPLOYMENT_TYPE="subdomain"
TRUST_PROXY="false" #(keep it true if behind a proxy like Nginx or Cloudflare)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# Any one of these bucket vars is accepted:
AWS_BUCKET_NAME="your-bucket-name"
# SANDBOX_S3_BUCKET="your-bucket-name"
# S3_BUCKET="your-bucket-name"
# Optional. Defaults to the main bucket if omitted.
# AWS_CDN_BUCKET_NAME="your-cdn"
# CDN_BUCKET_NAME="your-cdn"
# S3_CDN_BUCKET="your-cdn"
# Optional for S3-compatible providers. Leave unset for AWS S3.
# S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
ASSETS_URL="https://assets.yourdomain.com"
# Optional alias for ASSETS_URL:
# S3_PUBLIC_BASE_URL="https://your-bucket.s3.us-east-1.amazonaws.com"
CLOUDFRONT_DISTRIBUTION_URL="your-cloudfront-url"
CLOUDFRONT_DISTRIBUTION_ID="your-cloudfront-distribution-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_KV_NAMESPACE_ID="your-cloudflare-kv-namespace-id"
PREVIEW_ROOT_DOMAIN="edwardd.app"
TAVILY_API_KEY="tvly-your-tavily-api-key"
